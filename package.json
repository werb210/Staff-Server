{
  "name": "staff-server",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9.1",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/runMigrations.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "jest --config jest.config.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:runtime": "npm run build && node scripts/runtime-verify.js",
    "test:codex:server": "node scripts/codex-server-test.js",
    "user:set-role": "tsx scripts/set-user-role.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,js}\" --max-warnings=0",
    "workers": "tsx scripts/startWorkers.ts",
    "routes:export": "node --import tsx scripts/export-routes.ts",
    "drift:check": "bash scripts/api-drift-check.sh",
    "test:db:runtime": "npm run build && node scripts/db-runtime-integration.js",
    "e2e": "playwright test",
    "test:all": "npm run test && npm run e2e"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.29.1",
    "@types/multer": "^2.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "applicationinsights": "^3.12.1",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "file-type": "^21.3.2",
    "googleapis": "^133.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.34",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "openai": "^6.22.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "twilio": "^5.13.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "pg-mem": "^3.0.5",
    "playwright": "^1.58.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
