{
  "name": "bf-server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "postinstall": "echo skipping prisma generate in CI",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "NODE_ENV=test vitest",
    "ci:contract": "bash scripts/ci-contract-checks.sh",
    "prisma:generate": "prisma generate",
    "verify:no-direct-query": "rg -n \"pool.query\\(|client.query\\(\" src && exit 1 || exit 0",
    "verify:no-db-bypass": "rg -n \"getDb|queryDb|pool.query\" src && exit 1 || exit 0"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.5.0",
    "applicationinsights": "^3.14.0",
    "axios": "^1.14.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "file-type": "^21.3.4",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.40",
    "multer": "^2.1.1",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.13.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^2.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "pg-mem": "^3.0.14",
    "prisma": "^7.5.0",
    "supertest": "^6.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.10.0 <21.0.0"
  },
  "overrides": {
    "rollup": "4.13.0"
  }
}
