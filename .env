# BF-Server environment — copy this to .env and fill in real values
# DO NOT commit real secrets to this file

NODE_ENV=production
PORT=8080

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

CORS_ALLOWED_ORIGINS=https://boreal.financial,https://www.boreal.financial,https://client.boreal.financial,https://staff.boreal.financial,https://server.boreal.financial

CLIENT_URL=https://client.boreal.financial
PORTAL_URL=https://staff.boreal.financial
WEBSITE_URL=https://boreal.financial

# REQUIRED: Generate with: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

# REQUIRED: From OpenAI dashboard
OPENAI_API_KEY=REPLACE_WITH_REAL_KEY

# REQUIRED: From Twilio console → Verify → Services
# Must start with VA and be a real Service SID, not a placeholder
TWILIO_VERIFY_SERVICE_SID=REPLACE_WITH_REAL_VA_SID
