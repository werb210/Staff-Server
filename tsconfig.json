{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "noEmitOnError": false,
    "resolveJsonModule": true,
    "rootDir": "src",
    "moduleResolution": "node"
  },
  "exclude": [
    "node_modules",
    "backup",
    "**/*.backup.ts",
    "**/*.bak.ts"
  ],
  "include": [
    "src/**/*.ts"
  ]
}
