{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "target": "ES2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "types": [
      "node"
    ],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*"
  ]
}
