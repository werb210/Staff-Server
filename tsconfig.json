{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/__tests__/**",
    "tests/**",
    "src/test/**",
    "src/tests/**"
  ]
}
