{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "noImplicitAny": true
  },
  "include": [
    "src/**/*.ts",
    "src/server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
