{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "strict": false,
    "noImplicitAny": false,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "outDir": "dist"
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
