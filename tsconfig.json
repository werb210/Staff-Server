{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": false,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*.d.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "coverage",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.e2e.test.ts",
    "src/tests/**",
    "src/e2e/**",
    "src/pg-runquery.d.ts"
  ]
}
