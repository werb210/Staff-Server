NODE_ENV=test
PORT=4001

# JWT
JWT_SECRET=test-secret
ACCESS_TOKEN_SECRET=test-access
REFRESH_TOKEN_SECRET=test-refresh

# DB (use pg-mem or fallback local)
DATABASE_URL=postgresql://test:test@localhost:5432/test_db

# REDIS (mock or local)
REDIS_URL=redis://localhost:6379

# DISABLE EXTERNAL SERVICES
AZURE_STORAGE_ACCOUNT=disabled
AZURE_STORAGE_KEY=disabled
AZURE_BLOB_CONTAINER=disabled

SENDGRID_API_KEY=disabled
TWILIO_ACCOUNT_SID=disabled
TWILIO_AUTH_TOKEN=disabled

LOG_LEVEL=debug
