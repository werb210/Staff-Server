{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmitOnError": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "**/__tests__/**",
    "src/server/**",
    "src/bootstrapSafe.ts",
    "src/infra/**",
    "src/platform/**",
    "src/modules/**"
  ]
}
