generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Lender {
  id        String           @id @default(uuid())
  name      String
  products  LenderProduct[]
  createdAt DateTime         @default(now())
}

model LenderProduct {
  id        String   @id @default(uuid())
  lenderId  String
  name      String
  createdAt DateTime @default(now())

  lender Lender @relation(fields: [lenderId], references: [id])
}
