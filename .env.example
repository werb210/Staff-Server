# NOTE: Use real production secrets locally; placeholder values are rejected in production startup checks.
NODE_ENV=development
PORT=8080
BASE_URL=https://staff.example.com
DATABASE_URL=postgres://user:password@localhost:5432/staff
CORS_ALLOWED_ORIGINS=https://staff.boreal.financial
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_HISTORY=true
ENABLE_RETRY_POLICY=true
ENABLE_IDEMPOTENCY=true
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_CLOCK_SKEW_SECONDS=60

BUILD_TIMESTAMP=2024-01-01T00:00:00Z
COMMIT_SHA=local-dev
RUN_MIGRATIONS=false

LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_MAX_AGE_DAYS=90

LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX=10
REFRESH_RATE_LIMIT_WINDOW_MS=60000
PASSWORD_RESET_RATE_LIMIT_MAX=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=60000
DOCUMENT_UPLOAD_RATE_LIMIT_MAX=20
DOCUMENT_UPLOAD_RATE_LIMIT_WINDOW_MS=60000
LENDER_SUBMISSION_RATE_LIMIT_MAX=10
LENDER_SUBMISSION_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=120
ADMIN_RATE_LIMIT_WINDOW_MS=60000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
AI_SYSTEM_NAME=Maya
AI_MODEL=gpt-4o-mini
AI_EMBED_MODEL=text-embedding-3-small
INTAKE_SMS_NUMBER=+15878881837

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_VOICE_APP_SID=
TWILIO_PHONE_NUMBER=
# Verified Twilio number used as outbound caller ID for Voice SDK dials.
TWILIO_CALLER_ID=

O365_SHARED_INBOX_EMAIL=info@boreal.financial
# Optional for future confidential-client refresh token flows:
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
